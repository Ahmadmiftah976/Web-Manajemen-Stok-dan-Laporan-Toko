# ============================================================
# MajmaInsight — Environment Configuration
# ============================================================
# Salin file ini menjadi .env dan isi dengan konfigurasi Anda.
# Perintah: copy .env.example .env
# ============================================================

# ── Aplikasi ───────────────────────────────────────────────
APP_NAME="MajmaInsight"
APP_ENV=development
APP_URL=http://localhost/majmainsight/public
APP_TIMEZONE=Asia/Makassar

# ── Database (PostgreSQL) ──────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=majmainsight_db
DB_USER=postgres
DB_PASS=

# ── Midtrans Payment Gateway ──────────────────────────────
MIDTRANS_ENV=sandbox
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=

# ── Session ────────────────────────────────────────────────
SESSION_LIFETIME=7200
SESSION_NAME=majma_session
